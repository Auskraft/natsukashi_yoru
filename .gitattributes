# Единые переносы строк в репозитории (хранится LF; в рабочей копии — как у ОС).
* text=auto

# Скрипты под конкретную ОС.
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf
gradlew text eol=lf

# Бинарные ассеты — Git их не трогает.
*.png      binary
*.jpg      binary
*.jpeg     binary
*.gif      binary
*.ico      binary
*.webp     binary
*.ttf      binary
*.otf      binary
*.jar      binary
*.keystore binary

# ── GitHub Linguist ─────────────────────────────────────────────────────────
# По желанию владельца: НЕ показывать Dart в статистике языков репозитория.
# Помечаем весь Dart как vendored — Linguist исключает его из подсчёта.
# (Побочный эффект: на GitHub диффы .dart-файлов по умолчанию свёрнуты — их
#  всегда можно развернуть кликом.)
*.dart         linguist-vendored
*.g.dart       linguist-vendored
*.freezed.dart linguist-vendored
